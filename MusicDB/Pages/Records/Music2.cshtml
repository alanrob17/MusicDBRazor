@page
@model MusicDB.Pages.Records.Music2Model
@{
    ViewData["Title"] = "Music Player";
}

<div class="player-container">
    <h2>Streaming Music Player</h2>

    <!-- HTML5 Audio Player -->
    <audio id="audioPlayer" controls autoplay></audio>

    <!-- Playlist -->
    <ul id="playlist" class="playlist-group">
        @for (int i = 0; i < Model.Playlist.Count; i++)
        {
            <li class="playlist-item" data-src="@Model.Playlist[i].FileUrl">
                Track @(i + 1): <span class="track-name">@Model.Playlist[i].Title</span>
            </li>
        }
    </ul>
</div>

<style>
    .player-container {
        max-width: 600px;
        margin: 30px auto;
        font-family: sans-serif;
        text-align: center;
    }

    #audioPlayer {
        width: 100%;
        margin-bottom: 20px;
    }

    .playlist-group {
        list-style: none;
        padding: 0;
        text-align: left;
    }

    .playlist-item {
        padding: 10px;
        border-bottom: 1px solid #ddd;
        cursor: pointer;
    }

        .playlist-item:hover {
            background-color: #f0f0f0;
        }

        .playlist-item.active {
            font-weight: bold;
            color: #007bff;
        }
</style>

<script>
    const audioPlayer = document.getElementById('audioPlayer');
    const tracks = document.querySelectorAll('.playlist-item');
    let currentTrackIndex = 0;

    function loadTrack(index) {
        if (index >= tracks.length) return;

        // Update active styling
        tracks.forEach(t => t.classList.remove('active'));
        tracks[index].classList.add('active');

        // Get the data-src and log it
        const src = tracks[index].getAttribute('data-src');
        console.log(`Loading track ${index}:`, src);

        // Set the source
        audioPlayer.src = src;

        // Add error handler to catch playback issues
        audioPlayer.onerror = (e) => {
            console.error('Audio player error:');
            console.error('Error code:', audioPlayer.error?.code);
            console.error('Error message:', audioPlayer.error?.message);
        };

        audioPlayer.play().catch(err => {
            console.error('Play failed:', err);
        });
        currentTrackIndex = index;
    }

    // Click to play specific track
    tracks.forEach((track, index) => {
        track.addEventListener('click', () => {
            console.log(`Clicked track ${index}`);
            loadTrack(index);
        });
    });

    // Auto-play next track on end
    audioPlayer.addEventListener('ended', () => {
        console.log('Track ended, loading next');
        loadTrack(currentTrackIndex + 1);
    });

    // Load the first track initially
    if (tracks.length > 0) {
        console.log('Loading initial track');
        loadTrack(0);
    }
</script>

