@page
@model MusicDB.Pages.Records.IndexModel

@{
    ViewData["Title"] = "Records";

    const int windowSize = 15;
    int totalPages  = Model.TotalPages;
    int currentPage = Model.CurrentPage;
    int windowStart = ((currentPage - 1) / windowSize) * windowSize + 1;
    int windowEnd   = Math.Min(windowStart + windowSize - 1, totalPages);
    int prevWindowPage = windowStart - 1;
    int nextWindowPage = windowEnd   + 1;
}

<style>
    .records-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        padding-bottom: 0.75rem;
        border-bottom: 2px solid #dee2e6;
    }
    .records-header h1 {
        font-size: 1.75rem;
        font-weight: 700;
        color: #1a1a2e;
        margin: 0;
    }
    .record-count {
        font-size: 0.85rem;
        color: #6c757d;
        font-weight: 500;
    }
    .btn-create {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        border: none;
        padding: 0.45rem 1.1rem;
        border-radius: 6px;
        font-size: 0.875rem;
        font-weight: 600;
        text-decoration: none;
        transition: opacity 0.2s, transform 0.1s;
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
    }
    .btn-create:hover { opacity: 0.88; transform: translateY(-1px); color: #fff; text-decoration: none; }

    /* Search */
    .search-container { margin-bottom: 1.5rem; }
    .search-form { display: flex; gap: 0.75rem; max-width: 600px; }
    .search-input-wrapper { position: relative; flex-grow: 1; display: flex; align-items: center; }
    .search-icon { position: absolute; left: 0.9rem; color: #adb5bd; font-size: 0.9rem; pointer-events: none; }
    .search-input {
        width: 100%; padding: 0.55rem 2.2rem 0.55rem 2.2rem;
        font-size: 0.9rem; color: #212529; background: #fff;
        border: 1.5px solid #dee2e6; border-radius: 7px;
        transition: border-color 0.2s, box-shadow 0.2s;
    }
    .search-input:focus { outline: none; border-color: #667eea; box-shadow: 0 0 0 3px rgba(102,126,234,0.15); }
    .clear-search-btn { position: absolute; right: 0.9rem; color: #adb5bd; font-size: 0.8rem; text-decoration: none; transition: color 0.15s; }
    .clear-search-btn:hover { color: #dc3545; text-decoration: none; }
    .btn-search {
        background: #e9ecef; color: #495057; font-size: 0.875rem; font-weight: 600;
        padding: 0.55rem 1.2rem; border: 1.5px solid #dee2e6; border-radius: 7px;
        cursor: pointer; transition: background 0.2s, color 0.2s, border-color 0.2s;
    }
    .btn-search:hover { background: #667eea; color: #fff; border-color: #667eea; }

    /* Table */
    .records-card { background: #fff; border-radius: 10px; box-shadow: 0 2px 12px rgba(0,0,0,0.08); overflow: hidden; margin-bottom: 1.5rem; }
    .records-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    .records-table thead { background: linear-gradient(135deg, #1a1a2e, #16213e); color: #fff; }
    .records-table thead th { padding: 0.85rem 1rem; font-weight: 600; font-size: 0.8rem; letter-spacing: 0.05em; text-transform: uppercase; white-space: nowrap; border: none; }
    .records-table tbody tr { border-bottom: 1px solid #f1f3f5; transition: background 0.15s; }
    .records-table tbody tr:last-child { border-bottom: none; }
    .records-table tbody tr:hover { background: #f8f5ff; }
    .records-table tbody tr:nth-child(even) { background: #fafafa; }
    .records-table tbody tr:nth-child(even):hover { background: #f8f5ff; }
    .records-table td { padding: 0.7rem 1rem; vertical-align: middle; }
    .td-artist { font-weight: 600; color: #1a1a2e; white-space: nowrap; }
    .td-name { color: #212529; }
    .td-year { text-align: center; color: #6c757d; font-size: 0.85rem; }
    .td-actions { white-space: nowrap; text-align: right; }
    .action-link { font-size: 0.8rem; font-weight: 600; padding: 0.25rem 0.6rem; border-radius: 5px; text-decoration: none; margin-left: 0.3rem; transition: opacity 0.15s, transform 0.1s; display: inline-block; }
    .action-link:hover { opacity: 0.8; transform: translateY(-1px); text-decoration: none; }
    .action-edit    { background: #e8f4fd; color: #1a73e8; }
    .action-details { background: #e8f5e9; color: #2e7d32; }
    .action-delete  { background: #fce4ec; color: #c62828; }

    /* Pagination */
    .pagination-bar { display: flex; flex-wrap: wrap; gap: 0.4rem; justify-content: center; margin-top: 1rem; }
    .page-btn {
        display: inline-flex; align-items: center; justify-content: center;
        min-width: 2.2rem; height: 2.2rem; padding: 0 0.6rem;
        border-radius: 6px; font-size: 0.82rem; font-weight: 600;
        text-decoration: none; border: 1.5px solid #dee2e6;
        color: #495057; background: #fff; transition: all 0.15s;
    }
    .page-btn:hover { background: #667eea; color: #fff; border-color: #667eea; text-decoration: none; }
    .page-btn.active { background: linear-gradient(135deg,#667eea,#764ba2); color: #fff; border-color: transparent; }
    .nav-btn { background: #f1f3f5; color: #495057; }
    .pagination-info { font-size: 0.82rem; color: #6c757d; text-align: center; margin-bottom: 0.5rem; }
</style>

<div class="records-header">
    <div>
        @if (!string.IsNullOrWhiteSpace(Model.SearchString) && Model.MatchedArtistName != null)
        {
            <h1>💿 @Model.MatchedArtistName</h1>
            <span class="record-count">
                @Model.TotalCount record@(Model.TotalCount != 1 ? "s" : "") &nbsp;·&nbsp;
                Page @currentPage of @totalPages
            </span>
        }
        else if (!string.IsNullOrWhiteSpace(Model.SearchString) && Model.TotalCount == 0)
        {
            <h1>💿 No artist found</h1>
            <span class="record-count">No records matched "@Model.SearchString"</span>
        }
        else
        {
            <h1>💿 Records</h1>
            <span class="record-count">
                @Model.TotalCount record@(Model.TotalCount != 1 ? "s" : "") &nbsp;·&nbsp;
                Page @currentPage of @totalPages
            </span>
        }
    </div>
    <a asp-page="Create" class="btn-create">
        <span>＋</span> New Record
    </a>
</div>

<div class="search-container">
    <form method="get" class="search-form">
        <div class="search-input-wrapper">
            <span class="search-icon">🔍</span>
            <input type="text" name="SearchString" value="@Model.SearchString" class="search-input" placeholder="Search by artist name..." />
            @if (!string.IsNullOrEmpty(Model.SearchString))
            {
                <a asp-page="./Index" class="clear-search-btn" title="Clear search">✖</a>
            }
        </div>
        <button type="submit" class="btn-search">Search</button>
    </form>
</div>

<div class="records-card">
    <table class="records-table">
        <thead>
            <tr>
                <th>Artist</th>
                <th>Record Name</th>
                <th>Year</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Record)
            {
                <tr>
                    <td class="td-artist">@item.Artist?.Name</td>
                    <td class="td-name">@item.Name</td>
                    <td class="td-year">@item.Recorded</td>
                    <td class="td-actions">
                        <a asp-page="./Edit"    asp-route-id="@item.RecordId" class="action-link action-edit">Edit</a>
                        <a asp-page="./Details" asp-route-id="@item.RecordId" class="action-link action-details">Details</a>
                        <a asp-page="./Delete"  asp-route-id="@item.RecordId" class="action-link action-delete">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (totalPages > 1)
{
    <p class="pagination-info">
        Showing records @(((currentPage - 1) * MusicDB.Pages.Records.IndexModel.PageSize) + 1)
        – @(Math.Min(currentPage * MusicDB.Pages.Records.IndexModel.PageSize, Model.TotalCount))
        of @Model.TotalCount
    </p>

    <div class="pagination-bar">
        @if (windowStart > 1)
        {
            <a asp-page="./Index" asp-route-pageNumber="@prevWindowPage" asp-route-searchString="@Model.SearchString" class="page-btn nav-btn">&#8249; Prev 15</a>
        }
        @for (int p = windowStart; p <= windowEnd; p++)
        {
            <a asp-page="./Index"
               asp-route-pageNumber="@p"
               asp-route-searchString="@Model.SearchString"
               class="page-btn @(p == currentPage ? "active" : "")">@p</a>
        }
        @if (windowEnd < totalPages)
        {
            <a asp-page="./Index" asp-route-pageNumber="@nextWindowPage" asp-route-searchString="@Model.SearchString" class="page-btn nav-btn">Next 15 &#8250;</a>
        }
    </div>
}
