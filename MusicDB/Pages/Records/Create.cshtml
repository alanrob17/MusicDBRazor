@page
@model MusicDB.Pages.Records.CreateModel

@{
    ViewData["Title"] = "Create Record";
}



<div class="create-wrapper">
    <div class="create-card">
        <div class="create-card-header">
            <div class="create-avatar">➕</div>
            <div class="create-header-text">
                <h1>Create Record</h1>
                <span class="create-subtitle">💿 Add a new record to the database</span>
            </div>
        </div>

        <form method="post">
            <div class="create-card-body">
                <div asp-validation-summary="ModelOnly" class="validation-summary text-danger"></div>

                <p class="field-section-title">Artist</p>
                <div class="field-row full-width">
                    <div class="field-group">
                        <label asp-for="Record.ArtistId" class="field-label"></label>
                        <select asp-for="Record.ArtistId" asp-items="Model.ArtistList" class="field-input">
                            <option value="">— Select an Artist —</option>
                        </select>
                        <span asp-validation-for="Record.ArtistId" class="field-error"></span>
                    </div>
                </div>

                <hr class="field-divider" />

                <p class="field-section-title">Record Details</p>
                <div class="field-row full-width">
                    <div class="field-group">
                        <label asp-for="Record.Name" class="field-label"></label>
                        <input asp-for="Record.Name" class="field-input" placeholder="Record title" />
                        <span asp-validation-for="Record.Name" class="field-error"></span>
                    </div>
                </div>
                <div class="field-row full-width">
                    <div class="field-group">
                        <label asp-for="Record.SubTitle" class="field-label"></label>
                        <input asp-for="Record.SubTitle" class="field-input" placeholder="Sub title or edition" />
                        <span asp-validation-for="Record.SubTitle" class="field-error"></span>
                    </div>
                </div>
                <div class="field-row">
                    <div class="field-group">
                        <label asp-for="Record.Recorded" class="field-label"></label>
                        <input asp-for="Record.Recorded" class="field-input" placeholder="e.g. 1975" />
                        <span asp-validation-for="Record.Recorded" class="field-error"></span>
                    </div>
                    <div class="field-group">
                        <label asp-for="Record.Discs" class="field-label"></label>
                        <input asp-for="Record.Discs" class="field-input" placeholder="Number of discs" />
                        <span asp-validation-for="Record.Discs" class="field-error"></span>
                    </div>
                </div>
                <div class="field-row">
                    <div class="field-group">
                        <label asp-for="Record.Field" class="field-label"></label>
                        <input asp-for="Record.Field" class="field-input" placeholder="Genre / field" />
                        <span asp-validation-for="Record.Field" class="field-error"></span>
                    </div>
                    <div class="field-group">
                        <label asp-for="Record.Length" class="field-label"></label>
                        <input asp-for="Record.Length" class="field-input" placeholder="e.g. 52:14" />
                        <span asp-validation-for="Record.Length" class="field-error"></span>
                    </div>
                </div>

                <hr class="field-divider" />

                <p class="field-section-title">Review</p>
                <div class="field-row full-width">
                    <div class="field-group">
                        <label asp-for="Record.Review" class="field-label"></label>
                        <textarea asp-for="Record.Review" class="field-input textarea-review" placeholder="Enter review (HTML is supported)…"></textarea>
                        <span asp-validation-for="Record.Review" class="field-error"></span>
                    </div>
                </div>

                <hr class="field-divider" />

                <p class="field-section-title">System</p>
                <div class="field-row">
                    <div class="field-group">
                        <label asp-for="Record.CoverName" class="field-label"></label>
                        <input asp-for="Record.CoverName" class="field-input" placeholder="Cover image filename" />
                        <span asp-validation-for="Record.CoverName" class="field-error"></span>
                    </div>
                    <div class="field-group">
                        <label asp-for="Record.Folder" class="field-label"></label>
                        <input asp-for="Record.Folder" class="field-input" placeholder="Folder path" />
                        <span asp-validation-for="Record.Folder" class="field-error"></span>
                    </div>
                </div>
            </div>

            <div class="create-card-footer">
                <button type="submit" class="btn-action btn-create">➕ Create Record</button>
                <a asp-page="./Index" class="btn-action btn-back">← Back to Records</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
