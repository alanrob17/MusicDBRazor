@page
@model MusicDB.Pages.Records.DetailsModel

@{
    ViewData["Title"] = (Model.Record.Name ?? "Record") + " — Details";
    var record = Model.Record;
    string initial = record.Name?.Length > 0 ? record.Name[0].ToString().ToUpper() : "R";
}



<div class="details-wrapper">
    <div class="record-card">
        <div class="record-card-header">
            <div class="record-avatar">💿</div>
            <div class="record-header-text">
                <h1>@(record.Name ?? "Unknown Record")</h1>
                <span class="record-subtitle">@(record.Artist?.Name ?? "Unknown Artist") @(record.Recorded.HasValue ? "· " + record.Recorded : "")</span>
            </div>
        </div>

        <div class="record-card-body">
            <div class="detail-grid">

                <div class="detail-row">
                    <span class="detail-label">Artist</span>
                    <span class="detail-value">@(record.Artist?.Name ?? "—")</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Name</span>
                    <span class="detail-value">@(record.Name ?? "—")</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Sub Title</span>
                    <span class="detail-value @(string.IsNullOrWhiteSpace(record.SubTitle) ? "empty" : "")">@(string.IsNullOrWhiteSpace(record.SubTitle) ? "—" : record.SubTitle)</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Recorded</span>
                    <span class="detail-value @(record.Recorded == null ? "empty" : "")">@(record.Recorded?.ToString() ?? "—")</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Discs</span>
                    <span class="detail-value @(record.Discs == null ? "empty" : "")">@(record.Discs?.ToString() ?? "—")</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Field</span>
                    <span class="detail-value @(string.IsNullOrWhiteSpace(record.Field) ? "empty" : "")">@(string.IsNullOrWhiteSpace(record.Field) ? "—" : record.Field)</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Length</span>
                    <span class="detail-value @(string.IsNullOrWhiteSpace(record.Length) ? "empty" : "")">@(string.IsNullOrWhiteSpace(record.Length) ? "—" : record.Length)</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Cover Name</span>
                    <span class="detail-value @(string.IsNullOrWhiteSpace(record.CoverName) ? "empty" : "")">@(string.IsNullOrWhiteSpace(record.CoverName) ? "—" : record.CoverName)</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Folder</span>
                    <span class="detail-value @(string.IsNullOrWhiteSpace(record.Folder) ? "empty" : "")">@(string.IsNullOrWhiteSpace(record.Folder) ? "—" : record.Folder)</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Review</span>
                    <div class="detail-value @(string.IsNullOrWhiteSpace(record.Review) ? "empty" : "")">
                        @if (string.IsNullOrWhiteSpace(record.Review)) { <span>No review available.</span> }
                        else { @Html.Raw(record.Review) }
                    </div>
                </div>

            </div>
        </div>

        <div class="record-card-footer">
            <a asp-page="./Edit" asp-route-id="@record.RecordId" class="btn-action btn-edit">✏️ Edit</a>
            <a asp-page="./Index" class="btn-action btn-back">← Back to Records</a>
        </div>
    </div>
</div>
