@page
@model MusicDB.Pages.Artists.IndexModel

@{
    ViewData["Title"] = "Artists";

    // Pagination window: 15 buttons at a time
    const int windowSize = 15;
    int totalPages  = Model.TotalPages;
    int currentPage = Model.CurrentPage;

    // Calculate the start of the current 15-page window
    int windowStart = ((currentPage - 1) / windowSize) * windowSize + 1;
    int windowEnd   = Math.Min(windowStart + windowSize - 1, totalPages);

    int prevWindowPage = windowStart - 1;           // last page of the previous window
    int nextWindowPage = windowEnd   + 1;           // first page of the next window
}

<div class="artists-header">
    <div>
        <h1>🎵 Artists</h1>
        <span class="record-count">
            @Model.TotalCount artist@(Model.TotalCount != 1 ? "s" : "") &nbsp;·&nbsp;
            Page @currentPage of @totalPages
        </span>
    </div>
    <a asp-page="Create" class="btn-create">
        <span>＋</span> New Artist
    </a>
</div>

<div class="search-container">
    <form method="get" class="search-form">
        <div class="search-input-wrapper">
            <span class="search-icon">🔍</span>
            <input type="text" name="SearchString" value="@Model.SearchString" class="search-input" placeholder="Search by artist name..." />
            @if (!string.IsNullOrEmpty(Model.SearchString))
            {
                <a asp-page="./Index" class="clear-search-btn" title="Clear search">✖</a>
            }
        </div>
        <button type="submit" class="btn-search">Search</button>
    </form>
</div>

<div class="artists-card">
    <table class="artists-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Biography</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Artist)
            {
                <tr>
                    <td class="td-name">@item.Name</td>
                    <td class="td-bio">
                        @if (item.Biography != null)
                        {
                            @(item.Biography.Length > 60 ? item.Biography[..60] + "…" : item.Biography)
                        }
                    </td>
                    <td class="td-actions">
                        <a asp-page="./Edit"    asp-route-id="@item.ArtistId" class="action-link action-edit">Edit</a>
                        <a asp-page="./Details" asp-route-id="@item.ArtistId" class="action-link action-details">Details</a>
                        <a asp-page="./Delete"  asp-route-id="@item.ArtistId" class="action-link action-delete">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@* ── Pagination ──────────────────────────────────────────── *@
@if (totalPages > 1)
{
    <p class="pagination-info">
        Showing records @(((currentPage - 1) * MusicDB.Pages.Artists.IndexModel.PageSize) + 1)
        – @(Math.Min(currentPage * MusicDB.Pages.Artists.IndexModel.PageSize, Model.TotalCount))
        of @Model.TotalCount
    </p>

    <div class="pagination-bar">

        @* ◀ Previous 15-page window *@
        @if (windowStart > 1)
        {
            <a asp-page="./Index" asp-route-pageNumber="@prevWindowPage" asp-route-searchString="@Model.SearchString" class="page-btn nav-btn" title="Previous 15 pages">&#8249; Prev 15</a>
        }

        @* Numbered page buttons *@
        @for (int p = windowStart; p <= windowEnd; p++)
        {
            <a asp-page="./Index"
               asp-route-pageNumber="@p"
               asp-route-searchString="@Model.SearchString"
               class="page-btn @(p == currentPage ? "active" : "")">@p</a>
        }

        @* Next 15-page window ▶ *@
        @if (windowEnd < totalPages)
        {
            <a asp-page="./Index" asp-route-pageNumber="@nextWindowPage" asp-route-searchString="@Model.SearchString" class="page-btn nav-btn" title="Next 15 pages">Next 15 &#8250;</a>
        }

    </div>
}
