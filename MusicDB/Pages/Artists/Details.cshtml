@page
@model MusicDB.Pages.Artists.DetailsModel

@{
    ViewData["Title"] = Model.Artist.Name + " — Details";
    var artist = Model.Artist;
    string initials = string.Concat(
        (artist.FirstName?.Length > 0 ? artist.FirstName[0].ToString() : ""),
        (artist.LastName?.Length  > 0 ? artist.LastName[0].ToString()  : "")
    );
    if (initials.Length == 0) initials = artist.Name?.Length > 0 ? artist.Name[0].ToString() : "?";
}

<div class="details-wrapper">
    <div class="artist-card">

        @* Header *@
        <div class="artist-card-header">
            <div class="artist-avatar">@initials</div>
            <div class="artist-header-text">
                <h1>@(artist.Name ?? "Unknown Artist")</h1>
                @if (!string.IsNullOrWhiteSpace(artist.FirstName) || !string.IsNullOrWhiteSpace(artist.LastName))
                {
                    <span class="artist-subtitle italic">@artist.FirstName @artist.LastName</span>
                }
            </div>
        </div>

        @* Body *@
        <div class="artist-card-body">
            <div class="detail-grid">

                <div class="detail-row">
                    <span class="detail-label">First Name</span>
                    <span class="detail-value @(string.IsNullOrWhiteSpace(artist.FirstName) ? "empty" : "")">
                        @(string.IsNullOrWhiteSpace(artist.FirstName) ? "—" : artist.FirstName)
                    </span>
                </div>

                <div class="detail-row">
                    <span class="detail-label">Last Name</span>
                    <span class="detail-value @(string.IsNullOrWhiteSpace(artist.LastName) ? "empty" : "")">
                        @(string.IsNullOrWhiteSpace(artist.LastName) ? "—" : artist.LastName)
                    </span>
                </div>

                <div class="detail-row">
                    <span class="detail-label">Name</span>
                    <span class="detail-value">@artist.Name</span>
                </div>

                <div class="detail-row">
                    <span class="detail-label">Biography</span>
                    <div class="detail-value biography @(string.IsNullOrWhiteSpace(artist.Biography) ? "empty" : "")">
                        @if (string.IsNullOrWhiteSpace(artist.Biography))
                        {
                            <span>No biography available.</span>
                        }
                        else
                        {
                            @Html.Raw(artist.Biography)
                        }
                    </div>
                </div>

                <div class="detail-row">
                    <span class="detail-label">Folder</span>
                    <span class="detail-value @(string.IsNullOrWhiteSpace(artist.Folder) ? "empty" : "")">
                        @(string.IsNullOrWhiteSpace(artist.Folder) ? "—" : artist.Folder)
                    </span>
                </div>

                <div class="detail-row">
                    <span class="detail-label">Record Artist ID</span>
                    <span class="detail-value @(artist.RecordArtistId == null ? "empty" : "")">
                        @(artist.RecordArtistId?.ToString() ?? "—")
                    </span>
                </div>

            </div>
        </div>

        @* Footer *@
        <div class="artist-card-footer">
            <a asp-page="./Edit" asp-route-id="@artist.ArtistId" class="btn-action btn-primary-action">
                ✏️ Edit
            </a>
            <a asp-page="./Index" class="btn-action btn-back">
                ← Back to Artists
            </a>
        </div>

    </div>
</div>
