@page
@model MusicDB.Pages.Artists.ArtistSearchModel
@{
    ViewData["Title"] = "Artist Search";
}

@if (Model.SelectedArtist == null)
{
    @* ── SEARCH & SELECTION MODE ── *@
    <div class="form-wrapper">
        <div class="form-card" style="max-width: 600px; margin: 2rem auto;">
            
            <div class="form-card-header">
                <div class="form-avatar">🔍</div>
                <div class="form-header-text">
                    <h1>Artist Search</h1>
                    <span class="form-subtitle">Search or select an artist to view their records</span>
                </div>
            </div>

            <form method="get">
                <div class="form-card-body">
                    
                    @* Search input for filtering dropdown *@
                    <div class="field-group">
                        <label class="field-label" for="artistSearchInput">Search Artist Name</label>
                        <div class="d-flex gap-2">
                            <input type="text" id="artistSearchInput" name="SearchString" value="@Model.SearchString" class="field-input" placeholder="Type to filter artists..." autocomplete="off" />
                            <button type="submit" class="btn-action btn-back" style="margin: 0; min-width: 80px;" title="Filter dropdown server-side">Filter</button>
                        </div>
                        <span class="field-error" style="font-size: 0.8rem; color: #6c757d; margin-top: 0.2rem; display: block;">
                            Dropdown filters automatically as you type. Click "Filter" to filter server-side.
                        </span>
                    </div>

                    <hr class="field-divider" />

                    @* Dropdown list *@
                    <div class="field-group">
                        <label class="field-label" for="artistSelect">Select Artist</label>
                        <select id="artistSelect" name="SelectedArtistId" class="field-input" required>
                            <option value="">-- Choose an Artist --</option>
                            @foreach (var item in Model.ArtistSelectList)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        </select>
                    </div>

                </div>

                <div class="form-card-footer">
                    <button type="submit" class="btn-action btn-primary-action">💿 Show Records</button>
                    <a asp-page="./Index" class="btn-action btn-back">← Back to Artists</a>
                </div>
            </form>

        </div>
    </div>
}
else
{
    @* ── RECORDS DISPLAY MODE ── *@
    <div class="records-header">
        <div>
            <h1>💿 Records for @Model.SelectedArtist.Name</h1>
            <span class="record-count">
                @Model.TotalCount record@(Model.TotalCount != 1 ? "s" : "") &nbsp;·&nbsp;
                Page @Model.CurrentPage of @Model.TotalPages
            </span>
        </div>
        <a asp-page="./ArtistSearch" class="btn-create">
            <span>←</span> Search Another Artist
        </a>
    </div>

    <div class="records-card">
        <table class="records-table">
            <thead>
                <tr>
                    <th>Record Name</th>
                    <th>Sub Title</th>
                    <th>Year</th>
                    <th>Discs</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Records != null && Model.Records.Any())
                {
                    @foreach (var item in Model.Records)
                    {
                        <tr>
                            <td class="td-name">
                                <a asp-page="/Records/GetRecord" asp-route-recordId="@item.RecordId">@item.Name</a>
                            </td>
                            <td class="td-subtitle">@item.SubTitle</td>
                            <td class="td-year">@item.Recorded</td>
                            <td class="td-discs">@item.Discs</td>
                            <td class="td-actions">
                                <a asp-page="/Records/Edit"    asp-route-id="@item.RecordId" class="action-link action-edit">Edit</a>
                                <a asp-page="/Records/Details" asp-route-id="@item.RecordId" class="action-link action-details">Details</a>
                                <a asp-page="/Records/Delete"  asp-route-id="@item.RecordId" class="action-link action-delete">Delete</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">No records found for this artist.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* Pagination *@
    @if (Model.TotalPages > 1)
    {
        <p class="pagination-info">
            Showing records @(((Model.CurrentPage - 1) * MusicDB.Pages.Artists.ArtistSearchModel.PageSize) + 1)
            – @(Math.Min(Model.CurrentPage * MusicDB.Pages.Artists.ArtistSearchModel.PageSize, Model.TotalCount))
            of @Model.TotalCount
        </p>

        <div class="pagination-bar">
            @* ◀ Previous 15-page window *@
            @if (Model.WindowStart > 1)
            {
                <a asp-page="./ArtistSearch" asp-route-pageNumber="@Model.PrevWindowPage" asp-route-SelectedArtistId="@Model.SelectedArtistId" class="page-btn nav-btn" title="Previous 15 pages">&#8249; Prev 15</a>
            }

            @* Numbered page buttons *@
            @for (int p = Model.WindowStart; p <= Model.WindowEnd; p++)
            {
                <a asp-page="./ArtistSearch"
                   asp-route-pageNumber="@p"
                   asp-route-SelectedArtistId="@Model.SelectedArtistId"
                   class="page-btn @(p == Model.CurrentPage ? "active" : "")">@p</a>
            }

            @* Next 15-page window ▶ *@
            @if (Model.WindowEnd < Model.TotalPages)
            {
                <a asp-page="./ArtistSearch" asp-route-pageNumber="@Model.NextWindowPage" asp-route-SelectedArtistId="@Model.SelectedArtistId" class="page-btn nav-btn" title="Next 15 pages">Next 15 &#8250;</a>
            }
        </div>
    }
}

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const searchInput = document.getElementById("artistSearchInput");
            const artistSelect = document.getElementById("artistSelect");

            if (searchInput && artistSelect) {
                // Keep a copy of the original options
                const originalOptions = Array.from(artistSelect.options);

                searchInput.addEventListener("input", function () {
                    const filterText = searchInput.value.toLowerCase().trim();
                    const selectedValue = artistSelect.value;

                    // Clear options
                    artistSelect.innerHTML = "";

                    // Filter matching options
                    originalOptions.forEach(option => {
                        if (option.value === "" || option.text.toLowerCase().includes(filterText)) {
                            artistSelect.appendChild(option.cloneNode(true));
                        }
                    });

                    // Restore selected value if still present in filtered list
                    artistSelect.value = selectedValue;
                });
            }
        });
    </script>
}
