@page
@model MusicDB.Pages.Artists.EditModel

@{
    ViewData["Title"] = "Edit — " + Model.Artist.Name;
    var artist = Model.Artist;
    string initials = string.Concat(
        (artist.FirstName?.Length > 0 ? artist.FirstName[0].ToString() : ""),
        (artist.LastName?.Length  > 0 ? artist.LastName[0].ToString()  : "")
    );
    if (initials.Length == 0) initials = artist.Name?.Length > 0 ? artist.Name[0].ToString() : "?";
}

<div class="form-wrapper">
    <div class="form-card">

        @* ── Header ── *@
        <div class="form-card-header">
            <div class="form-avatar">@initials</div>
            <div class="form-header-text">
                <h1>@(artist.Name ?? "Edit Artist")</h1>
                <span class="form-subtitle">✏️ Editing artist record</span>
            </div>
        </div>

        @* ── Form ── *@
        <form method="post">
            <input type="hidden" asp-for="Artist.ArtistId" />

            <div class="form-card-body">

                @* Validation summary *@
                <div asp-validation-summary="ModelOnly" class="validation-summary text-danger"></div>

                @* Name fields *@
                <p class="field-section-title">Identity</p>
                <div class="field-row">
                    <div class="field-group">
                        <label asp-for="Artist.FirstName" class="field-label"></label>
                        <input asp-for="Artist.FirstName" class="field-input" placeholder="First name" />
                        <span asp-validation-for="Artist.FirstName" class="field-error"></span>
                    </div>
                    <div class="field-group">
                        <label asp-for="Artist.LastName" class="field-label"></label>
                        <input asp-for="Artist.LastName" class="field-input" placeholder="Last name" />
                        <span asp-validation-for="Artist.LastName" class="field-error"></span>
                    </div>
                </div>

                <div class="field-row full-width">
                    <div class="field-group">
                        <label asp-for="Artist.Name" class="field-label"></label>
                        <input asp-for="Artist.Name" class="field-input" placeholder="Stage or full name" />
                        <span asp-validation-for="Artist.Name" class="field-error"></span>
                    </div>
                </div>

                <hr class="field-divider" />

                @* Biography *@
                <p class="field-section-title">Biography</p>
                <div class="field-row full-width">
                    <div class="field-group">
                        <label asp-for="Artist.Biography" class="field-label"></label>
                        <textarea asp-for="Artist.Biography" class="field-input textarea-bio" placeholder="Enter biography (HTML is supported)…"></textarea>
                        <span asp-validation-for="Artist.Biography" class="field-error"></span>
                    </div>
                </div>

                <hr class="field-divider" />

                @* System fields *@
                <p class="field-section-title">System</p>
                <div class="field-row">
                    <div class="field-group">
                        <label asp-for="Artist.Folder" class="field-label"></label>
                        <input asp-for="Artist.Folder" class="field-input" placeholder="Folder path" />
                        <span asp-validation-for="Artist.Folder" class="field-error"></span>
                    </div>
                    <div class="field-group">
                        <label asp-for="Artist.RecordArtistId" class="field-label"></label>
                        <input asp-for="Artist.RecordArtistId" class="field-input" placeholder="Linked record ID" />
                        <span asp-validation-for="Artist.RecordArtistId" class="field-error"></span>
                    </div>
                </div>

            </div>

            @* ── Footer ── *@
            <div class="form-card-footer">
                <button type="submit" class="btn-action btn-primary-action">💾 Save Changes</button>
                <a asp-page="./Index" class="btn-action btn-back">← Back to Artists</a>
            </div>
        </form>

    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
