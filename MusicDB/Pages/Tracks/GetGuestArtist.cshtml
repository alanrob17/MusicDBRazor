@page
@model MusicDB.Pages.Tracks.GetGuestArtistModel

<link rel="stylesheet" href="~/css/tracks.css" />

@{
    ViewData["Title"] = "Guest Artist Tracks";

    const int windowSize = 15;
    int totalPages  = Model.TotalPages;
    int currentPage = Model.CurrentPage;
    int windowStart = ((currentPage - 1) / windowSize) * windowSize + 1;
    int windowEnd   = Math.Min(windowStart + windowSize - 1, totalPages);
    int prevWindowPage = windowStart - 1;
    int nextWindowPage = windowEnd   + 1;

    bool hasSearch  = !string.IsNullOrWhiteSpace(Model.SearchString);
    bool hasResults = Model.Tracks.Count > 0;
}

<div class="tracks-header">
    <div>
        <h1>🎤 Guest Artist Tracks</h1>
        @if (hasSearch && hasResults)
        {
            <span class="record-count">
                @Model.TotalCount track@(Model.TotalCount != 1 ? "s" : "") matching "@Model.SearchString" &nbsp;·&nbsp;
                Page @currentPage of @totalPages
            </span>
        }
        else if (hasSearch)
        {
            <span class="record-count">No tracks found for "@Model.SearchString"</span>
        }
        else
        {
            <span class="record-count">Enter an artist name to search</span>
        }
    </div>
    <a asp-page="./Index" class="btn-back btn-action">← Back to Tracks</a>
</div>

<div class="search-container">
    <form method="get" class="search-form">
        <div class="search-input-wrapper">
            <span class="search-icon">🔍</span>
            <input type="text" name="SearchString" value="@Model.SearchString"
                   class="search-input" placeholder="Search by guest artist name..." />
            @if (hasSearch)
            {
                <a asp-page="./GetGuestArtist" class="clear-search-btn" title="Clear search">✖</a>
            }
        </div>
        <button type="submit" class="btn-search">Search</button>
    </form>
</div>

@if (hasSearch)
{
    <div class="tracks-card">
        <table class="tracks-table">
            <thead>
                <tr>
                    <th>Artist</th>
                    <th>Record</th>
                    <th>Recorded</th>
                    <th>Disc</th>
                    <th>#</th>
                    <th>Track Name</th>
                    <th>Length</th>
                </tr>
            </thead>
            <tbody>
                @if (hasResults)
                {
                    @foreach (var item in Model.Tracks)
                    {
                        <tr>
                            <td class="td-artist">@item.ArtistName</td>
                            <td class="td-album">@item.RecordName</td>
                            <td class="td-disc">@item.Recorded</td>
                            <td class="td-disc">@item.DiscName</td>
                            <td>@item.Number</td>
                            <td class="td-name">@item.FullTrackName</td>
                            <td class="td-length">@item.Length</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" style="text-align:center; padding: 2rem; color:#6c757d; font-style:italic;">
                            No guest artist tracks found for "@Model.SearchString".
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* ── Pagination ──────────────────────────────────────────── *@
    @if (totalPages > 1)
    {
        <p class="pagination-info">
            Showing records @(((currentPage - 1) * MusicDB.Pages.Tracks.GetGuestArtistModel.PageSize) + 1)
            – @(Math.Min(currentPage * MusicDB.Pages.Tracks.GetGuestArtistModel.PageSize, Model.TotalCount))
            of @Model.TotalCount
        </p>

        <div class="pagination-bar">

            @* ◀ Previous 15-page window *@
            @if (windowStart > 1)
            {
                <a asp-page="./GetGuestArtist"
                   asp-route-pageNumber="@prevWindowPage"
                   asp-route-searchString="@Model.SearchString"
                   class="page-btn nav-btn" title="Previous 15 pages">&#8249; Prev 15</a>
            }

            @* Numbered page buttons *@
            @for (int p = windowStart; p <= windowEnd; p++)
            {
                <a asp-page="./GetGuestArtist"
                   asp-route-pageNumber="@p"
                   asp-route-searchString="@Model.SearchString"
                   class="page-btn @(p == currentPage ? "active" : "")">@p</a>
            }

            @* Next 15-page window ▶ *@
            @if (windowEnd < totalPages)
            {
                <a asp-page="./GetGuestArtist"
                   asp-route-pageNumber="@nextWindowPage"
                   asp-route-searchString="@Model.SearchString"
                   class="page-btn nav-btn" title="Next 15 pages">Next 15 &#8250;</a>
            }

        </div>
    }
}
