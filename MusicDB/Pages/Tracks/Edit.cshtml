@page
@model MusicDB.Pages.Tracks.EditModel

@{
    ViewData["Title"] = "Edit — " + (Model.Track.Title ?? "Track");
    var track = Model.Track;
    string initial = track.Title?.Length > 0 ? track.Title[0].ToString().ToUpper() : "♪";
}

<div class="form-wrapper">
    <div class="form-card">

        @* ── Header ── *@
        <div class="form-card-header">
            <div class="form-avatar">@initial</div>
            <div class="form-header-text">
                <h1>@(track.Title ?? "Edit Track")</h1>
                <span class="form-subtitle">✏️ Editing track record</span>
            </div>
        </div>

        @* ── Form ── *@
        <form method="post">
            <input type="hidden" asp-for="Track.TrackId" />

            <div class="form-card-body">

                @* Validation summary *@
                <div asp-validation-summary="ModelOnly" class="validation-summary text-danger"></div>

                @* Disc *@
                <p class="field-section-title">Disc</p>
                <div class="field-row full-width">
                    <div class="field-group">
                        <label asp-for="Track.DiscId" class="field-label"></label>
                        <select asp-for="Track.DiscId" asp-items="Model.DiscList" class="field-input"></select>
                        <span asp-validation-for="Track.DiscId" class="field-error"></span>
                    </div>
                </div>

                <hr class="field-divider" />

                @* Identity *@
                <p class="field-section-title">Identity</p>
                <div class="field-row">
                    <div class="field-group">
                        <label asp-for="Track.Name" class="field-label"></label>
                        <input asp-for="Track.Name" class="field-input" placeholder="Track name" />
                        <span asp-validation-for="Track.Name" class="field-error"></span>
                    </div>
                    <div class="field-group">
                        <label asp-for="Track.Title" class="field-label"></label>
                        <input asp-for="Track.Title" class="field-input" placeholder="Track title" />
                        <span asp-validation-for="Track.Title" class="field-error"></span>
                    </div>
                </div>

                <div class="field-row">
                    <div class="field-group">
                        <label asp-for="Track.Artist" class="field-label"></label>
                        <input asp-for="Track.Artist" class="field-input" placeholder="Artist" />
                        <span asp-validation-for="Track.Artist" class="field-error"></span>
                    </div>
                    <div class="field-group">
                        <label asp-for="Track.Album" class="field-label"></label>
                        <input asp-for="Track.Album" class="field-input" placeholder="Album" />
                        <span asp-validation-for="Track.Album" class="field-error"></span>
                    </div>
                </div>

                <hr class="field-divider" />

                @* Numbering & Year *@
                <p class="field-section-title">Numbering &amp; Year</p>
                <div class="field-row">
                    <div class="field-group">
                        <label asp-for="Track.Number" class="field-label"></label>
                        <input asp-for="Track.Number" type="number" class="field-input" placeholder="Track number" />
                        <span asp-validation-for="Track.Number" class="field-error"></span>
                    </div>
                    <div class="field-group">
                        <label asp-for="Track.DiscNumber" class="field-label"></label>
                        <input asp-for="Track.DiscNumber" type="number" class="field-input" placeholder="Disc number" />
                        <span asp-validation-for="Track.DiscNumber" class="field-error"></span>
                    </div>
                </div>

                <div class="field-row">
                    <div class="field-group">
                        <label asp-for="Track.Recorded" class="field-label"></label>
                        <input asp-for="Track.Recorded" type="number" class="field-input" placeholder="Year recorded" />
                        <span asp-validation-for="Track.Recorded" class="field-error"></span>
                    </div>
                    <div class="field-group">
                        <label asp-for="Track.Length" class="field-label"></label>
                        <input asp-for="Track.Length" class="field-input" placeholder="e.g. 3:45" />
                        <span asp-validation-for="Track.Length" class="field-error"></span>
                    </div>
                </div>

                <div class="field-row">
                    <div class="field-group">
                        <label asp-for="Track.Duration" class="field-label"></label>
                        <input asp-for="Track.Duration" class="field-input" placeholder="hh:mm:ss" />
                        <span asp-validation-for="Track.Duration" class="field-error"></span>
                    </div>
                    <div class="field-group">
                        <label asp-for="Track.Media" class="field-label"></label>
                        <input asp-for="Track.Media" class="field-input" placeholder="Media type" />
                        <span asp-validation-for="Track.Media" class="field-error"></span>
                    </div>
                </div>

                <hr class="field-divider" />

                @* Audio *@
                <p class="field-section-title">Audio</p>
                <div class="field-row">
                    <div class="field-group">
                        <label asp-for="Track.Bits" class="field-label"></label>
                        <input asp-for="Track.Bits" type="number" class="field-input" placeholder="Bits" />
                        <span asp-validation-for="Track.Bits" class="field-error"></span>
                    </div>
                    <div class="field-group">
                        <label asp-for="Track.BitRate" class="field-label"></label>
                        <input asp-for="Track.BitRate" type="number" class="field-input" placeholder="kbps" />
                        <span asp-validation-for="Track.BitRate" class="field-error"></span>
                    </div>
                </div>

                <div class="field-row">
                    <div class="field-group">
                        <label asp-for="Track.AudioSampleRate" class="field-label"></label>
                        <input asp-for="Track.AudioSampleRate" type="number" class="field-input" placeholder="Hz" />
                        <span asp-validation-for="Track.AudioSampleRate" class="field-error"></span>
                    </div>
                    <div class="field-group">
                        <label asp-for="Track.AudioChannels" class="field-label"></label>
                        <input asp-for="Track.AudioChannels" type="number" class="field-input" placeholder="Channels" />
                        <span asp-validation-for="Track.AudioChannels" class="field-error"></span>
                    </div>
                </div>

                <hr class="field-divider" />

                @* System *@
                <p class="field-section-title">System</p>
                <div class="field-row full-width">
                    <div class="field-group">
                        <label asp-for="Track.Field" class="field-label"></label>
                        <input asp-for="Track.Field" class="field-input" placeholder="Field" />
                        <span asp-validation-for="Track.Field" class="field-error"></span>
                    </div>
                </div>

                <div class="field-row full-width">
                    <div class="field-group">
                        <label asp-for="Track.Folder" class="field-label"></label>
                        <input asp-for="Track.Folder" class="field-input" placeholder="Folder path" />
                        <span asp-validation-for="Track.Folder" class="field-error"></span>
                    </div>
                </div>

            </div>

            @* ── Footer ── *@
            <div class="form-card-footer">
                <button type="submit" class="btn-action btn-primary-action">💾 Save Changes</button>
                <a asp-page="./Index" class="btn-action btn-back">← Back to Tracks</a>
            </div>
        </form>

    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
