@page
@model MusicDB.Pages.Tracks.DetailsModel

@{
    ViewData["Title"] = (Model.Track.Title ?? "Track") + " — Details";
    var track = Model.Track;
    var record = track.Disc?.Record;
    string initial = track.Title?.Length > 0 ? track.Title[0].ToString().ToUpper() : "♪";
}

<div class="details-wrapper">
    <div class="track-card">

        @* Header *@
        <div class="track-card-header">
            <div class="track-avatar">@initial</div>
            <div class="track-header-text">
                <h1>@(track.Title ?? "Unnamed Track")</h1>
                @if (!string.IsNullOrWhiteSpace(track.Artist))
                {
                    <span class="track-subtitle" style="font-size: 1.2rem; font-style: normal;"><a asp-page="/Artists/ArtistSearch" asp-route-SelectedArtistId="@record.ArtistId">@track.Artist</a></span>
                }
            </div>
        </div>

        @* Body *@
        <div class="track-card-body">
            <div class="detail-grid">

                <div class="detail-row">
                    <span class="detail-label">Disc / Record</span>
                    <span class="detail-value @(track.Disc == null ? "empty" : "")">
                        @if (track.Disc != null)
                        {
                            @(track.Disc.Name ?? "—")
                            if (track.Disc.Record != null)
                            {
                                <span> (Record: @track.Disc.Record.Name)</span>
                            }
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </span>
                </div>

                <div class="detail-row">
                    <span class="detail-label">Track Name</span>
                    <span class="detail-value @(string.IsNullOrWhiteSpace(track.Name) ? "empty" : "")">
                        @(string.IsNullOrWhiteSpace(track.Name) ? "—" : track.Name)
                    </span>
                </div>

                <div class="detail-row">
                    <span class="detail-label">Track Title</span>
                    <span class="detail-value @(string.IsNullOrWhiteSpace(track.Title) ? "empty" : "")">
                        @(string.IsNullOrWhiteSpace(track.Title) ? "—" : track.Title)
                    </span>
                </div>

                <div class="detail-row">
                    <span class="detail-label">Artist</span>
                    <span class="detail-value @(string.IsNullOrWhiteSpace(track.Artist) ? "empty" : "")">
                        @(string.IsNullOrWhiteSpace(track.Artist) ? "—" : track.Artist)
                    </span>
                </div>

                <div class="detail-row">
                    <span class="detail-label">Album</span>
                    <span class="detail-value @(string.IsNullOrWhiteSpace(track.Album) ? "empty" : "")">
                        @(string.IsNullOrWhiteSpace(track.Album) ? "—" : track.Album)
                    </span>
                </div>

                <div class="detail-row">
                    <span class="detail-label">Track Number</span>
                    <span class="detail-value @(track.Number == null ? "empty" : "")">
                        @(track.Number?.ToString() ?? "—")
                    </span>
                </div>

                <div class="detail-row">
                    <span class="detail-label">Disc Number</span>
                    <span class="detail-value @(track.DiscNumber == null ? "empty" : "")">
                        @(track.DiscNumber?.ToString() ?? "—")
                    </span>
                </div>

                <div class="detail-row">
                    <span class="detail-label">Recorded Year</span>
                    <span class="detail-value @(track.Recorded == null ? "empty" : "")">
                        @(track.Recorded?.ToString() ?? "—")
                    </span>
                </div>

                <div class="detail-row">
                    <span class="detail-label">Length</span>
                    <span class="detail-value @(string.IsNullOrWhiteSpace(track.Length) ? "empty" : "")">
                        @(string.IsNullOrWhiteSpace(track.Length) ? "—" : track.Length)
                    </span>
                </div>

                <div class="detail-row">
                    <span class="detail-label">Duration</span>
                    <span class="detail-value @(track.Duration == null ? "empty" : "")">
                        @(track.Duration?.ToString(@"hh\:mm\:ss") ?? "—")
                    </span>
                </div>

                <div class="detail-row">
                    <span class="detail-label">Media</span>
                    <span class="detail-value @(string.IsNullOrWhiteSpace(track.Media) ? "empty" : "")">
                        @(string.IsNullOrWhiteSpace(track.Media) ? "—" : track.Media)
                    </span>
                </div>

                <div class="detail-row">
                    <span class="detail-label">Field</span>
                    <span class="detail-value @(string.IsNullOrWhiteSpace(track.Field) ? "empty" : "")">
                        @(string.IsNullOrWhiteSpace(track.Field) ? "—" : track.Field)
                    </span>
                </div>

                <div class="detail-row">
                    <span class="detail-label">Bits</span>
                    <span class="detail-value @(track.Bits == null ? "empty" : "")">
                        @(track.Bits?.ToString() ?? "—")
                    </span>
                </div>

                <div class="detail-row">
                    <span class="detail-label">Bit Rate</span>
                    <span class="detail-value @(track.BitRate == null ? "empty" : "")">
                        @(track.BitRate == null ? "—" : track.BitRate.ToString() + " kbps")
                    </span>
                </div>

                <div class="detail-row">
                    <span class="detail-label">Sample Rate</span>
                    <span class="detail-value @(track.AudioSampleRate == null ? "empty" : "")">
                        @(track.AudioSampleRate == null ? "—" : track.AudioSampleRate.ToString() + " Hz")
                    </span>
                </div>

                <div class="detail-row">
                    <span class="detail-label">Channels</span>
                    <span class="detail-value @(track.AudioChannels == null ? "empty" : "")">
                        @(track.AudioChannels?.ToString() ?? "—")
                    </span>
                </div>

                <div class="detail-row">
                    <span class="detail-label">Folder</span>
                    <span class="detail-value @(string.IsNullOrWhiteSpace(track.Folder) ? "empty" : "")">
                        @(string.IsNullOrWhiteSpace(track.Folder) ? "—" : track.Folder)
                    </span>
                </div>

            </div>
        </div>

        @* Footer *@
        <div class="track-card-footer">
            <a asp-page="./Edit" asp-route-id="@track.TrackId" class="btn-action btn-primary-action">
                ✏️ Edit
            </a>
            <a asp-page="./Index" class="btn-action btn-back">
                ← Back to Tracks
            </a>
        </div>

    </div>
</div>
