@page
@model MusicDB.Pages.Tracks.IndexModel

@{
    ViewData["Title"] = "Tracks";

    const int windowSize = 15;
    int totalPages  = Model.TotalPages;
    int currentPage = Model.CurrentPage;
    int windowStart = ((currentPage - 1) / windowSize) * windowSize + 1;
    int windowEnd   = Math.Min(windowStart + windowSize - 1, totalPages);
    int prevWindowPage = windowStart - 1;
    int nextWindowPage = windowEnd   + 1;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Tracks</h1>
        <a asp-page="Create" class="btn btn-primary">New Track</a>
    </div>

    <form method="get" class="mb-4">
        <div class="input-group">
            <input type="text" name="SearchString" value="@Model.SearchString" class="form-control" placeholder="Search by name, title, or artist..." />
            <button type="submit" class="btn btn-outline-secondary">Search</button>
            @if (!string.IsNullOrEmpty(Model.SearchString))
            {
                <a asp-page="./Index" class="btn btn-outline-danger">Clear</a>
            }
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Name</th>
                    <th>Title</th>
                    <th>Artist</th>
                    <th>Length</th>
                    <th>Disc</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Track)
                {
                    <tr>
                        <td>@item.Number</td>
                        <td>@item.Name</td>
                        <td>@item.Title</td>
                        <td>@item.Artist</td>
                        <td>@item.Length</td>
                        <td>@(item.Disc?.Name ?? $"Disc {item.DiscNumber}")</td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <a asp-page="./Edit" asp-route-id="@item.TrackId" class="btn btn-outline-primary">Edit</a>
                                <a asp-page="./Details" asp-route-id="@item.TrackId" class="btn btn-outline-info">Details</a>
                                <a asp-page="./Delete" asp-route-id="@item.TrackId" class="btn btn-outline-danger">Delete</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        <div class="d-flex justify-content-between align-items-center mt-3">
            <span class="text-muted small">
                Showing tracks @(((currentPage - 1) * MusicDB.Pages.Tracks.IndexModel.PageSize) + 1)
                – @(Math.Min(currentPage * MusicDB.Pages.Tracks.IndexModel.PageSize, Model.TotalCount))
                of @Model.TotalCount
            </span>

            <nav>
                <ul class="pagination pagination-sm m-0">
                    @if (windowStart > 1)
                    {
                        <li class="page-item">
                            <a asp-page="./Index" asp-route-pageNumber="@prevWindowPage" asp-route-searchString="@Model.SearchString" class="page-link">Prev 15</a>
                        </li>
                    }
                    @for (int p = windowStart; p <= windowEnd; p++)
                    {
                        <li class="page-item @(p == currentPage ? "active" : "")">
                            <a asp-page="./Index" asp-route-pageNumber="@p" asp-route-searchString="@Model.SearchString" class="page-link">@p</a>
                        </li>
                    }
                    @if (windowEnd < totalPages)
                    {
                        <li class="page-item">
                            <a asp-page="./Index" asp-route-pageNumber="@nextWindowPage" asp-route-searchString="@Model.SearchString" class="page-link">Next 15</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>
