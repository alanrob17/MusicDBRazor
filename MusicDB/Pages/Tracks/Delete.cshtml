@page
@model MusicDB.Pages.Tracks.DeleteModel

@{
    ViewData["Title"] = "Delete Track — " + Model.Track.Title;
    var track = Model.Track;
    string initial = track.Title?.Length > 0 ? track.Title[0].ToString().ToUpper() : "♪";
}

<div class="details-wrapper">
    <div class="track-card">

        @* Header *@
        <div class="track-card-header danger">
            <div class="track-avatar danger">@initial</div>
            <div class="track-header-text">
                <h1>Delete @(track.Title ?? "Track")?</h1>
                <span class="track-subtitle delete-warning">
                    ⚠️ Warning: This action is permanent and cannot be undone.
                </span>
            </div>
        </div>

        @* Body *@
        <div class="track-card-body">

            <div class="delete-prompt-banner">
                <span>Are you sure you want to permanently delete this track from the database?</span>
            </div>

            <div class="detail-grid">

                <div class="detail-row">
                    <span class="detail-label">Disc / Record</span>
                    <span class="detail-value @(track.Disc == null ? "empty" : "")">
                        @if (track.Disc != null)
                        {
                            @(track.Disc.Name ?? "—")
                            if (track.Disc.Record != null)
                            {
                                <span> (Record: @track.Disc.Record.Name)</span>
                            }
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </span>
                </div>

                <div class="detail-row">
                    <span class="detail-label">Track Name</span>
                    <span class="detail-value @(string.IsNullOrWhiteSpace(track.Name) ? "empty" : "")">
                        @(string.IsNullOrWhiteSpace(track.Name) ? "—" : track.Name)
                    </span>
                </div>

                <div class="detail-row">
                    <span class="detail-label">Track Title</span>
                    <span class="detail-value @(string.IsNullOrWhiteSpace(track.Title) ? "empty" : "")">
                        @(string.IsNullOrWhiteSpace(track.Title) ? "—" : track.Title)
                    </span>
                </div>

                <div class="detail-row">
                    <span class="detail-label">Artist</span>
                    <span class="detail-value @(string.IsNullOrWhiteSpace(track.Artist) ? "empty" : "")">
                        @(string.IsNullOrWhiteSpace(track.Artist) ? "—" : track.Artist)
                    </span>
                </div>

                <div class="detail-row">
                    <span class="detail-label">Album</span>
                    <span class="detail-value @(string.IsNullOrWhiteSpace(track.Album) ? "empty" : "")">
                        @(string.IsNullOrWhiteSpace(track.Album) ? "—" : track.Album)
                    </span>
                </div>

                <div class="detail-row">
                    <span class="detail-label">Track Number</span>
                    <span class="detail-value @(track.Number == null ? "empty" : "")">
                        @(track.Number?.ToString() ?? "—")
                    </span>
                </div>

                <div class="detail-row">
                    <span class="detail-label">Recorded Year</span>
                    <span class="detail-value @(track.Recorded == null ? "empty" : "")">
                        @(track.Recorded?.ToString() ?? "—")
                    </span>
                </div>

            </div>
        </div>

        @* Footer *@
        <div class="track-card-footer">
            <form method="post">
                <input type="hidden" asp-for="Track.TrackId" />
                <button type="submit" class="btn-action btn-delete">
                    🗑️ Confirm Delete
                </button>
                <a asp-page="./Index" class="btn-action btn-back">
                    Cancel
                </a>
            </form>
        </div>

    </div>
</div>
